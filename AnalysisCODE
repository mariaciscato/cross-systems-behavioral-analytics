file.path(output_dir, "tables", "omaze_t\_test.csv"), row.names = FALSE)
write.csv(omaze_summary, file.path(output_dir, "tables",
"omaze_summary.csv"), row.names = FALSE)

plot_omaze \<- plot_bar_jitter( raw_data = omaze_pooled, summary_data =
omaze_summary, y_col = openperc, title = "O-maze: CTRL vs MPEG males",
y_label = "Time in open arms (%)", p_label = paste0("t-test p =",
signif(omaze_tests$t_test$p, 3)) )

ggsave( file.path(output_dir, "plots", "omaze_open_arms.pdf"),
plot_omaze, width = 8, height = 6 )

### 7. O-maze: binned ANOVA

omaze_anova \<- aov(open_combined \~ bin \* Treatment, data = omaze_raw)
omaze_anova_summary \<- summary(omaze_anova)

omaze_emmeans \<- emmeans(omaze_anova, \~ Treatment \* bin)
omaze_pairwise \<- contrast(omaze_emmeans, method = "pairwise", adjust =
"holm") %\>% summary() %\>% as.data.frame()

write.csv( omaze_pairwise, file.path(output_dir, "tables",
"omaze_binned_pairwise_holm.csv"), row.names = FALSE )

