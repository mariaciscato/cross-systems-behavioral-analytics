### 11. Open Field: transitions

transition_folder \<- file.path(base_dir, "Openfield/Locationoutput")

transition_counts \<- list.files( path = transition_folder, pattern =
"\\.csv\$", full.names = TRUE ) %\>% map_dfr(function(file) { df \<-
read.csv(file)

    if (!"ROI_transition" %in% names(df)) {
      return(tibble(file = basename(file), n_transitions = NA_integer_))
    }

    tibble(
      file = basename(file),
      n_transitions = sum(
        tolower(trimws(as.character(df$ROI_transition))) == "true",
        na.rm = TRUE
      )
    )

}) %\>% mutate(id = row_number()) %\>% left_join(animal_metadata, by =
"id")

transition_tests \<- run_group_tests(transition_counts, n_transitions)
