"B3/Omaze/OM_B415_LocationOutput.csv"), MPEG_1 = file.path(base_dir,
"Omaze/Batch2/09_10_2023_OMCM135mpeg_LocationOutput.csv") )

trajectory_plots \<- trajectory_files %\>% imap(function(path, name) {
data \<- read.csv(path) plot_trajectory(data, title = paste("O-maze
trajectory:", name)) })

iwalk(trajectory_plots, function(plot, name) { ggsave(
file.path(output_dir, "plots", paste0("trajectory\_", name, ".pdf")),
