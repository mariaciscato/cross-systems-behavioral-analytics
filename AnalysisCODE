correlation_results \<- correlation_df %\>% group_by(Treatment) %\>%
summarise( pearson_r = cor(openperc, centerperc, method = "pearson"),
pearson_p = cor.test(openperc, centerperc, method =
"pearson")$p.value,  spearman_rho = cor(openperc, centerperc, method = "spearman"),  spearman_p = cor.test(openperc, centerperc, method = "spearman")$p.value,
.groups = "drop" )

write.csv( correlation_df, file.path(output_dir, "tables",
"omaze_openfield_correlation_data.csv"), row.names = FALSE )

write.csv( correlation_results, file.path(output_dir, "tables",
"omaze_openfield_correlation_results.csv"), row.names = FALSE )

plot_correlation \<- ggplot(correlation_df, aes(x = openperc, y =
centerperc)) + geom_point(size = 4, color = "black") +
geom_smooth(method = "lm", se = FALSE, color = "black") + facet_wrap(\~
Treatment) + labs( title = "Correlation between O-maze and Open Field
anxiety metrics", x = "O-maze time in open arms (%)", y = "Open Field
time in center (%)" ) + theme_minimal()

ggsave( file.path(output_dir, "plots",
"omaze_openfield_correlation.pdf"), plot_correlation, width = 8, height
= 6 )

