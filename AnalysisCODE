### 1. Load packages

library(tidyverse) library(rstatix) library(ggplot2) library(emmeans)

### 2. Define paths

base_dir \<- "/Volumes/maria/Data/OpenfieldOmazeIPNanxiety/B4ki/Males"
output_dir \<- "outputs"

dir.create(output_dir, showWarnings = FALSE, recursive = TRUE)
dir.create(file.path(output_dir, "plots"), showWarnings = FALSE,
recursive = TRUE) dir.create(file.path(output_dir, "tables"),
showWarnings = FALSE, recursive = TRUE)

### 3. Helper functions

read_csv_files \<- function(files) { files %\>% map_dfr(read.csv) }

summarise_by_treatment \<- function(data, value_col) { data %\>%
group_by(Treatment) %\>% summarise( n = n(), mean = mean({{ value_col
}}, na.rm = TRUE), se = sd({{ value_col }}, na.rm = TRUE) / sqrt(n),
.groups = "drop" ) }

run_group_tests \<- function(data, value_col) { value_col \<-
enquo(value_col)

normality \<- data %\>% group_by(Treatment) %\>%
shapiro_test(!!value_col)

ttest \<- data %\>% t_test(!!value_col \~ Treatment)

list( normality = normality, t_test = ttest ) }

plot_bar_jitter \<- function(raw_data, summary_data, y_col, title,
y_label, p_label = NULL) { ggplot() + geom_col( data = summary_data,
aes(x = Treatment, y = mean, fill = Treatment), width = 0.45, color =
"black", alpha = 0.7 ) + geom_errorbar( data = summary_data, aes(x =
Treatment, ymin = mean - se, ymax = mean + se), width = 0.2, color =
"black" ) + geom_jitter( data = raw_data, aes(x = Treatment, y = {{
y_col }}), width = 0.15, shape = 1, color = "black", size = 4, alpha =
0.8, stroke = 1 ) + labs( title = title, subtitle = p_label, x =
"Treatment", y = y_label ) + theme_minimal() + theme(legend.position =
"none") }

plot_trajectory \<- function(data, title = NULL) { ggplot(data, aes(x =
X, y = Y)) + geom_path(color = "black", linewidth = 1) +
scale_y\_reverse() + coord_fixed() + labs(title = title) + theme_void()
}

### 4. Metadata

animal_metadata \<- tibble( id = 1:22, Treatment = factor( c( "CTRL",
"CTRL", "MPEG", "MPEG", "MPEG", "MPEG", "MPEG", "MPEG", "MPEG", "CTRL",
"MPEG", "MPEG", "CTRL", "CTRL", "MPEG", "MPEG", "MPEG", "CTRL", "CTRL",
"CTRL", "CTRL", "CTRL" ), levels = c("CTRL", "MPEG") ) )

